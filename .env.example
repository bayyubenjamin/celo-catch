# Celo Sepolia is the recommended MiniPay test network.
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_START_BLOCK=0

# Public project verification value supplied by Talent Protocol.
NEXT_PUBLIC_TALENT_PROJECT_VERIFICATION=

# The private key signs catch results. Never expose it with NEXT_PUBLIC_.
SERVER_SIGNER_PRIVATE_KEY=

# At least 32 random characters. Keeps each wallet's daily catch deterministic.
SERVER_RANDOMNESS_SECRET=
