{
  "name": "celo-catch",
  "version": "1.0.0",
  "private": true,
  "description": "A MiniPay-native daily onchain fishing game built for the Celo ecosystem.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "node scripts/compile-contract.mjs",
    "check:celo": "node scripts/check-celo-ecosystem.mjs",
    "check:minipay": "node scripts/check-minipay.mjs",
    "verify": "npm run typecheck && npm test && npm run test:contract && npm run check:celo && npm run check:minipay && npm run build"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.53.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "hardhat": "^2.28.6",
    "postcss": "8.5.15",
    "solc": "0.8.30",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3",
    "vitest": "3.2.4"
  },
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bayyubenjamin/celo-catch.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bayyubenjamin/celo-catch/issues"
  },
  "homepage": "https://github.com/bayyubenjamin/celo-catch#readme",
  "type": "module"
}
